# pyenv
#   For a library or package, you might want to ignore these files since the Python version
#   is generally handled via a build system or continuous integration.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in cases where the lock file contains system-specific dependencies, it may be useful to ignore it.
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally included in version control.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   Similar to Pipenv and Poetry, pdm.lock is generally included in version control.
#pdm.lock
#   pdm build indices
.pdm-build/

# PEP 582; used by e.g. github.com/frenzymadness/venva
